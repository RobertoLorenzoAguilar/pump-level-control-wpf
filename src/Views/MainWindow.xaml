<Window x:Class="PumpControl.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:PumpControl.Converters"
        Title="Castelec — Monitor Gas L.P." Height="760" Width="500"
        Background="#0D1117"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI"
        MinWidth="420" MinHeight="520">

    <Window.Resources>
        <local:LevelToColorConverter x:Key="LevelToColorConverter"/>
        <local:StatusToColorConverter x:Key="StatusToColorConverter"/>

        <!-- Estilo compartido para botones de control manual -->
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="12,9"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Width" Value="155"/>
        </Style>
    </Window.Resources>

    <DockPanel>

        <!-- ═══════════════════════ BARRA DE TÍTULO / HEADER ═══════════════════════ -->
        <Border DockPanel.Dock="Top" Background="#161B22" Padding="16,11"
                BorderBrush="#21262D" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <!-- Acento naranja Gas LP -->
                <Border Background="#F59E0B" Width="4" Height="30" CornerRadius="2" Margin="0,0,12,0"/>
                <StackPanel>
                    <TextBlock Text="CASTELEC INTERNACIONAL" FontSize="9" Foreground="#8B949E"
                               FontWeight="Bold" Margin="0,0,0,2"/>
                    <TextBlock Text="Sistema de Control — Gas L.P." FontSize="16"
                               Foreground="#E6EDF3" FontWeight="Bold"/>
                </StackPanel>
                <StackPanel Margin="18,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="● EN LÍNEA" FontSize="10" Foreground="#3FB950" FontWeight="SemiBold"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ═══════════════════════════ BANNER IMAGEN GAS LP ═══════════════════════ -->
        <Border DockPanel.Dock="Top" Height="145" Background="#0D1117" ClipToBounds="True">
            <Grid>
                <Image Source="pack://application:,,,/img/gaslp_pipeline.png"
                       Stretch="UniformToFill" Opacity="0.82"
                       VerticalAlignment="Center" HorizontalAlignment="Center"/>
                <!-- Sombras superior e inferior para que el contenido encaje limpiamente -->
                <Border>
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#CC0D1117" Offset="0.0"/>
                            <GradientStop Color="#000D1117" Offset="0.4"/>
                            <GradientStop Color="#000D1117" Offset="0.6"/>
                            <GradientStop Color="#CC0D1117" Offset="1.0"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>
                <TextBlock Text="Pipeline Gas L.P." FontSize="11" Foreground="#C8820055"
                           FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                           Margin="0,0,14,8"/>
            </Grid>
        </Border>

        <!-- ═══════════════════════════ CONTENIDO PRINCIPAL ════════════════════════ -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" Background="#0D1117">
            <StackPanel Margin="14,12,14,14">

                <!-- ─────────────── TARJETA: NIVEL DE LLENADO ─────────────── -->
                <Border Background="#161B22" CornerRadius="12" Padding="16"
                        BorderBrush="#21262D" BorderThickness="1" Margin="0,0,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="72"/>
                            <ColumnDefinition Width="18"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- BARRA VERTICAL TIPO TANQUE -->
                        <Grid Grid.Column="0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="LLENO" FontSize="8" Foreground="#6E7681"
                                       HorizontalAlignment="Center" Margin="0,0,0,4" FontWeight="Bold"/>

                            <Border Grid.Row="1" Background="#21262D" CornerRadius="8"
                                    BorderBrush="#30363D" BorderThickness="1.5">
                                <Grid Height="240" Margin="5">

                                    <!-- Barra de progreso vertical — usa DisplayLevel (0-100%) -->
                                    <ProgressBar Orientation="Vertical"
                                                 Value="{Binding DisplayLevel, Mode=OneWay}"
                                                 Minimum="0" Maximum="100"
                                                 Foreground="{Binding DisplayLevel, Mode=OneWay, Converter={StaticResource LevelToColorConverter}}"
                                                 Background="Transparent"
                                                 BorderThickness="0"
                                                 VerticalAlignment="Stretch"
                                                 HorizontalAlignment="Stretch"/>

                                    <!-- Marcas de referencia 75% / 50% / 25% -->
                                    <Canvas IsHitTestVisible="False">
                                        <Line X1="0"  Y1="60"  X2="62" Y2="60"
                                              Stroke="#30363D" StrokeThickness="1" StrokeDashArray="3,2"/>
                                        <Line X1="0"  Y1="120" X2="62" Y2="120"
                                              Stroke="#30363D" StrokeThickness="1" StrokeDashArray="3,2"/>
                                        <Line X1="0"  Y1="180" X2="62" Y2="180"
                                              Stroke="#30363D" StrokeThickness="1" StrokeDashArray="3,2"/>
                                        <TextBlock Canvas.Left="44" Canvas.Top="52"  Text="75%" FontSize="7" Foreground="#484F58"/>
                                        <TextBlock Canvas.Left="44" Canvas.Top="112" Text="50%" FontSize="7" Foreground="#484F58"/>
                                        <TextBlock Canvas.Left="44" Canvas.Top="172" Text="25%" FontSize="7" Foreground="#484F58"/>
                                    </Canvas>

                                    <!-- Porcentaje en texto sobrepuesto —usa DisplayLevel-->
                                    <TextBlock Text="{Binding DisplayLevel, Mode=OneWay, StringFormat={}{0:F0}%}"
                                               VerticalAlignment="Center" HorizontalAlignment="Center"
                                               Foreground="#E6EDF3" FontWeight="Bold" FontSize="11"
                                               IsHitTestVisible="False"/>
                                </Grid>
                            </Border>

                            <TextBlock Grid.Row="2" Text="VACÍO" FontSize="8" Foreground="#6E7681"
                                       HorizontalAlignment="Center" Margin="0,4,0,0" FontWeight="Bold"/>
                        </Grid>

                        <!-- LÍNEA DIVISORIA VERTICAL -->
                        <Border Grid.Column="1" Width="1" Background="#21262D"
                                VerticalAlignment="Stretch" HorizontalAlignment="Center"/>

                        <!-- PANEL DERECHO: PORCENTAJE + ESTADO -->
                        <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="14,0,0,0">

                            <!-- Número grande de porcentaje — DisplayLevel -->
                            <TextBlock Text="{Binding DisplayLevel, Mode=OneWay, StringFormat={}{0:F1}%}"
                                       FontSize="58" FontWeight="Bold" LineHeight="58"
                                       Foreground="{Binding DisplayLevel, Mode=OneWay, Converter={StaticResource LevelToColorConverter}}"/>

                            <TextBlock Text="Nivel de llenado" FontSize="11" Foreground="#6E7681"
                                       Margin="0,2,0,14"/>

                            <!-- Caja de texto de estado: "Nivel máximo alcanzado — Bomba apagada" etc. -->
                            <Border Background="#0D1117" CornerRadius="8" Padding="12,10"
                                    BorderBrush="#30363D" BorderThickness="1">
                                <TextBlock Text="{Binding FillStatusText}"
                                           FontSize="12" Foreground="#CDD9E5"
                                           TextWrapping="Wrap" LineHeight="18"/>
                            </Border>

                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ─────────────── TARJETA: ESTADO DE LA BOMBA ─────────────── -->
                <Border CornerRadius="12" Padding="14" Margin="0,0,0,10"
                        Background="{Binding PumpStatus, Converter={StaticResource StatusToColorConverter}}"
                        BorderBrush="#21262D" BorderThickness="1">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="⚙  BOMBA: " Foreground="#8B949E"
                                   FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding PumpStatus}" FontSize="14" FontWeight="Bold"
                                   Foreground="#E6EDF3" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- ─────────────── TARJETA: UMBRAL DE ACTIVACIÓN ─────────────── -->
                <Border Background="#161B22" CornerRadius="12" Padding="16" Margin="0,0,0,10"
                        BorderBrush="#21262D" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="UMBRAL DE ACTIVACIÓN" FontSize="9" Foreground="#6E7681"
                                   FontWeight="Bold" Margin="0,0,0,10"/>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Slider Width="265" Minimum="0" Maximum="100" VerticalAlignment="Center"
                                    Value="{Binding Threshold, UpdateSourceTrigger=PropertyChanged}"/>
                            <Border Background="#21262D" CornerRadius="6" Padding="10,5" Margin="12,0,0,0"
                                    BorderBrush="#30363D" BorderThickness="1">
                                <TextBlock Text="{Binding Threshold, StringFormat={}{0:F0}%}"
                                           FontWeight="Bold" Foreground="#79C0FF" FontSize="16"
                                           VerticalAlignment="Center"/>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ─────────────── TARJETA: CONTROL MANUAL ─────────────── -->
                <Border Background="#161B22" CornerRadius="12" Padding="16"
                        BorderBrush="#21262D" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="CONTROL MANUAL" FontSize="9" Foreground="#6E7681"
                                   FontWeight="Bold" Margin="0,0,0,12"/>
                        <CheckBox Content="  Habilitar modo manual"
                                  IsChecked="{Binding IsManualMode}"
                                  Foreground="#CDD9E5" FontSize="13" FontWeight="SemiBold"
                                  Margin="0,0,0,12"/>
                        <StackPanel Orientation="Horizontal" IsEnabled="{Binding IsManualMode}">
                            <Button Content="▶  Activar Bomba"
                                    Command="{Binding ForceOnCommand}"
                                    Style="{StaticResource ActionButtonStyle}"
                                    Background="#033A29" Foreground="#56D364"
                                    BorderBrush="#238636" Margin="0,0,10,0"/>
                            <Button Content="⏹  Apagar Bomba"
                                    Command="{Binding ForceOffCommand}"
                                    Style="{StaticResource ActionButtonStyle}"
                                    Background="#3D0A0A" Foreground="#FF7B72"
                                    BorderBrush="#6E1111"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>