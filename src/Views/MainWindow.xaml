<Window x:Class="PumpControl.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:PumpControl.Converters"
        Title="Castelec - Control de Llenado" Height="450" Width="400"
        Background="#F0F0F0">

    <Window.Resources>
        <local:LevelToColorConverter x:Key="LevelToColorConverter"/>
        <local:StatusToColorConverter x:Key="StatusToColorConverter"/>
    </Window.Resources>

    <Grid Margin="20">
        <StackPanel Margin="15">

            <TextBlock Text="MONITOREO DE NIVEL GAS LP" 
                       FontSize="20" FontWeight="Bold" Foreground="#2C3E50"
                       HorizontalAlignment="Center" Margin="0,0,0,20"/>

            <Grid Height="200" Width="100">
                <ProgressBar Orientation="Vertical" 
                             Value="{Binding CurrentLevel}" 
                             Minimum="0" Maximum="100"
                             Foreground="{Binding CurrentLevel, Converter={StaticResource LevelToColorConverter}}"/>

                <TextBlock Text="{Binding CurrentLevel, StringFormat={}{0:F1}%}" 
                           VerticalAlignment="Center" HorizontalAlignment="Center"
                           FontWeight="Bold" FontSize="16"/>
            </Grid>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="10">
                <TextBlock Text="Umbral de Activación: " VerticalAlignment="Center"/>
                <Slider Width="150" Minimum="0" Maximum="100" 
                        Value="{Binding Threshold, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBlock Text="{Binding Threshold, StringFormat={}{0:F0}%}" 
                           FontWeight="Bold" Margin="5,0,0,0"/>
            </StackPanel>

            <!-- Panel de Control Manual -->
            <StackPanel Margin="0,5,0,15" HorizontalAlignment="Center">
                <CheckBox Content="Habilitar Modo Manual" IsChecked="{Binding IsManualMode}" 
                          FontWeight="Bold" Margin="0,0,0,10" HorizontalAlignment="Center"/>
                
                <StackPanel Orientation="Horizontal" IsEnabled="{Binding IsManualMode}">
                    <Button Content="Activar (1)" Command="{Binding ForceOnCommand}" 
                            Width="80" Margin="0,0,10,0" Padding="5" 
                            Background="#D4EDDA" BorderBrush="#28A745" Cursor="Hand"/>
                    <Button Content="Apagar (0)" Command="{Binding ForceOffCommand}" 
                            Width="80" Padding="5" 
                            Background="#F8D7DA" BorderBrush="#DC3545" Cursor="Hand"/>
                </StackPanel>
            </StackPanel>

            <Border BorderBrush="Gray" BorderThickness="1" Padding="10" CornerRadius="5"
                    Background="{Binding PumpStatus, Converter={StaticResource StatusToColorConverter}}">
                <TextBlock Text="{Binding PumpStatus}" 
                           HorizontalAlignment="Center" FontSize="14" FontWeight="Bold"/>
            </Border>

        </StackPanel>
    </Grid>
</Window>