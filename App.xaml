<Application x:Class="PumpControl.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:PumpControl.Converters"
             StartupUri="src/Views/MainWindow.xaml">
    <Application.Resources>
        <!-- Registramos aquí los convertidores que usaremos libremente en todo el WPF -->
        <converters:LevelToColorConverter x:Key="LevelToColorConverter"/>
        <converters:StatusToColorConverter x:Key="StatusToColorConverter"/>
    </Application.Resources>
</Application>
